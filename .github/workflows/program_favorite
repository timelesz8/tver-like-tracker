name: お気に入り数取得

on:
  workflow_dispatch:
  schedule:
    - cron: "54 * * * *"

jobs:
  run-script:
    runs-on: ubuntu-latest

    steps:
      - uses: actions/checkout@v4

      - uses: actions/setup-python@v5
        with:
          python-version: "3.10"

      - uses: browser-actions/setup-chrome@v1

      - run: pip install selenium gspread google-auth

      - name: Run program_favorite
        env:
          GCP_SA_KEY: ${{ secrets.GCP_SA_KEY }}
          TVER_DATA_SHEET_ID: ${{ secrets.TVER_DATA_SHEET_ID }}
        run: python program_favorite.py
